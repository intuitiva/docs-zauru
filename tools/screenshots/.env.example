# ── Credenciales de Zauru (NUNCA subas valores reales a git) ─────────────
# La app redirige al proveedor OAuth (zauru-oauth-*.herokuapp.com) al entrar.
ZAURU_BASE_URL=https://zauru.herokuapp.com
ZAURU_EMAIL=tu-correo@ejemplo.com
ZAURU_PASSWORD=tu-password

# ── Selectores del formulario OAuth (POST /login; ajusta solo si difieren) ──
ZAURU_EMAIL_INPUT=input[name="username"]
ZAURU_PASSWORD_INPUT=input[name="password"]
ZAURU_SUBMIT_INPUT=button[type="submit"]

# ── Elementos a ocultar antes de capturar. En Zauru: logo, barra de
#    comunicación (notificaciones/tareas) y barra de usuario — la navegación
#    de módulos queda visible. Separados por coma.
ZAURU_HIDE_SELECTORS=#logo,#communication_toolbar,#user_toolbar

# ── Escala del screenshot (2 = retina, texto más nítido, archivos más grandes)
SCREENSHOT_SCALE=2

# ── Generación del manifiesto con OpenRouter (API compatible con OpenAI) ──
# Consigue tu key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Cualquier modelo de OpenRouter, p.ej. tencent/hy3:free, google/gemini-2.5-flash,
# deepseek/deepseek-chat-v3-0324:free
MANIFEST_MODEL=tencent/hy3:free
